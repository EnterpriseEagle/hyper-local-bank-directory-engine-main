# === DATABASE ===

# Local publish-first database
DATABASE_URL=file:./data/banknearme.db

# Optional auth token for a remote LibSQL/Turso database
# DATABASE_AUTH_TOKEN=

# Canonical public URL used for metadata, sitemap, and robots
# SITE_URL=https://banknearme.com.au

# === LAUNCH FLAGS ===

# Keep false until the production write database is ready
NEXT_PUBLIC_ENABLE_STATUS_REPORTS=false

# Optional photo upload + moderation queue on top of status reports
NEXT_PUBLIC_ENABLE_REPORT_EVIDENCE=false

# Keep false until the site is live and you have approved affiliate links
NEXT_PUBLIC_ENABLE_AFFILIATE_FEATURES=false

# === SUPABASE COMMUNITY REPORTS ===

# Use Supabase for photo evidence and the moderation queue
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_REPORTS_BUCKET=report-photos
# REPORTS_ADMIN_SECRET=your-random-admin-secret

# Optional real image review on top of metadata extraction
# ENABLE_OPENAI_REPORT_VISION=false
# OPENAI_API_KEY=sk-...
# OPENAI_REPORT_REVIEW_MODEL=gpt-4.1-mini

# === MONETIZATION ===

# Set these only when affiliate features are enabled
# RESEND_API_KEY=re_xxxxxxxxxxxx
# REPORT_EMAIL=you@example.com
# CRON_SECRET=your-random-secret-here
# AFFILIATE_OPS_SECRET=your-random-ops-secret

# Optional: agentic payout ops
# AFFILIATE_OPS_AUTO_CONTACT=false
# AFFILIATE_OPS_AUTO_PAUSE=false
# PAYOUT_FROM_EMAIL=NEAR ME NETWORK <ops@banknearme.com.au>
# AFFILIATE_CONTACT_EMAIL_UBANK_30=partner@example.com
# AFFILIATE_CONTACT_EMAIL_ING_125=partner@example.com
# AFFILIATE_CONTACT_EMAIL_AMEX_PLATINUM=partner@example.com

# === GOOGLE ANALYTICS ===

# Optional GA4 measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
